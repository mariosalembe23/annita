# API base URL (pode ser do teu backend ou de um proxy Next.js)
# Exemplo: http://localhost:8080/api
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Supabase credentials (para upload de imagens)
# Buscar em: https://supabase.com/dashboard/project/<project-id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google OAuth client ID (login com Google)
# Buscar em: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
  